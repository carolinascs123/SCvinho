-- Test 5: transfer custody from the vineyard to the winery
testTransferCustody : Script ()
testTransferCustody = script do

  vineyard <- allocateParty "Quinta Transfer Test"
  winery <- allocateParty "Sandeman Winery"
  ivdp <- allocateParty "IVDP Transfer Test"

  setTime (time (date 2026 Oct 2) 0 0 0)

  registryCid <- submit vineyard do
    createCmd WineBatchRegistry with
      vineyard = vineyard
      ivdp = ivdp

  batchCid <- submit vineyard do
    exerciseCmd registryCid CreateWineBatch with
      batchId = "PW-2026-0050"
      origin = Origin with
        region = "Douro Valley"
        latitude = 41.162
        longitude = -7.790
      harvestDate = time (date 2026 Sep 15) 0 0 0
      grapeVariety = "Touriga Nacional"
      bottleQR = "QR-NFC-88500"

  newBatchCid <- submit vineyard do
    exerciseCmd batchCid TransferCustody with
      newOwner = winery
      logisticsNote = None

  Some transferredBatch <- queryContractId winery newBatchCid

  assertMsg
    "The new owner should be Sandeman Winery"
    (transferredBatch.currentOwner == winery)

  assertMsg
    "The transfer should be recorded in the history"
    (length transferredBatch.history == 1)

  pure ()


-- Test 6: transfer custody through the complete supply chain
testMultipleCustodyTransfers : Script ()
testMultipleCustodyTransfers = script do

  vineyard <- allocateParty "Quinta Multi Transfer"
  winery <- allocateParty "Sandeman Multi Transfer"
  logistics <- allocateParty "LogisTrans"
  retailer <- allocateParty "ViniShop Oslo"
  ivdp <- allocateParty "IVDP Multi Transfer"

  setTime (time (date 2026 Oct 2) 0 0 0)

  registryCid <- submit vineyard do
    createCmd WineBatchRegistry with
      vineyard = vineyard
      ivdp = ivdp

  batchCid <- submit vineyard do
    exerciseCmd registryCid CreateWineBatch with
      batchId = "PW-2026-0051"
      origin = Origin with
        region = "Douro Valley"
        latitude = 41.162
        longitude = -7.790
      harvestDate = time (date 2026 Sep 15) 0 0 0
      grapeVariety = "Touriga Nacional"
      bottleQR = "QR-NFC-88501"

  -- Quinta -> Sandeman
  wineryBatchCid <- submit vineyard do
    exerciseCmd batchCid TransferCustody with
      newOwner = winery
      logisticsNote = None

  -- Sandeman -> LogisTrans
  logisticsBatchCid <- submit winery do
    exerciseCmd wineryBatchCid TransferCustody with
      newOwner = logistics
      logisticsNote =
        Some "Temperature 14-16C, Lisbon -> Oslo"

  -- LogisTrans -> ViniShop Oslo
  retailerBatchCid <- submit logistics do
    exerciseCmd logisticsBatchCid TransferCustody with
      newOwner = retailer
      logisticsNote = None

  Some finalBatch <- queryContractId retailer retailerBatchCid

  assertMsg
    "The final owner should be ViniShop Oslo"
    (finalBatch.currentOwner == retailer)

  assertMsg
    "Three custody transfers should be recorded"
    (length finalBatch.history == 3)

  pure ()



module Test where

import Daml.Script
import DA.Date
import DA.Time
import Main

-- Test 1: create a valid Port wine batch with a past harvest date
testCreateValidWineBatch : Script ()
testCreateValidWineBatch = script do

  vineyard <- allocateParty "Quinta do Vale"
  ivdp <- allocateParty "IVDP"

  setTime (time (date 2026 Oct 2) 0 0 0)

  registryCid <- submit vineyard do
    createCmd WineBatchRegistry with
      vineyard = vineyard
      ivdp = ivdp

  _ <- submit vineyard do
    exerciseCmd registryCid CreateWineBatch with
      batchId = "PW-2026-0042"
      origin = Origin with
        region = "Douro Valley"
        latitude = 41.162
        longitude = -7.790
      harvestDate = time (date 2026 Sep 15) 0 0 0
      grapeVariety = "Touriga Nacional"
      bottleQR = "QR-NFC-88421"

  pure ()


-- Test 2: reject a wine batch with an empty grape variety
testRejectEmptyGrapeVariety : Script ()
testRejectEmptyGrapeVariety = script do

  vineyard <- allocateParty "Quinta do Vale Invalid Test"
  ivdp <- allocateParty "IVDP Invalid Test"

  currentTime <- getTime

  submitMustFail vineyard do
    createCmd WineBatch with
      batchId = "PW-2026-0043"
      origin = Origin with
        region = "Douro Valley"
        latitude = 41.162
        longitude = -7.790
      harvestDate = currentTime
      grapeVariety = ""
      vineyard = vineyard
      currentOwner = vineyard
      ivdp = ivdp
      history = []
      certificationHash = None
      ipfsCid = None
      status = PENDING
      bottleQR = "QR-NFC-88422"


